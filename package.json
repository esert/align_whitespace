{
  "name": "align-whitespace",
  "displayName": "Align Whitespace",
  "description": "Align simple C/C++ declaration blocks using a Python formatter.",
  "version": "0.0.3",
  "publisher": "esert-local",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Formatters"
  ],
  "keywords": [
    "align",
    "whitespace",
    "cpp",
    "c++",
    "format"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./extension.js",
  "type": "commonjs",
  "activationEvents": [
    "onCommand:alignWhitespace.alignCppBlock"
  ],
  "contributes": {
    "commands": [
      {
        "command": "alignWhitespace.alignCppBlock",
        "title": "Align Whitespace: C/C++ Block",
        "category": "Align Whitespace"
      }
    ],
    "keybindings": [
      {
        "command": "alignWhitespace.alignCppBlock",
        "key": "f1",
        "when": "editorTextFocus && !editorReadonly && resourceScheme == file && resourceExtname =~ /^\\.(cpp|cc|cxx|h|hpp)$/"
      }
    ],
    "configuration": {
      "title": "Align Whitespace",
      "properties": {
        "alignWhitespace.pythonCommand": {
          "type": "string",
          "default": "python3",
          "description": "Python executable used to run the bundled formatter script."
        }
      }
    }
  }
}
